<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Aiko.UI.CtmGraphicsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Aiko.UI"
    x:Name="this"
    Loaded="this_Loaded">

    <ScrollView
        x:Name="scrol"
        BindingContext="{x:Reference this}"
        Orientation="Both">
        <local:ZoomPanContainer>
            <Grid
                x:Name="root"
                BackgroundColor="Yellow"
                SizeChanged="root_SizeChanged">

                <Image
                    x:Name="backgroundImage"
                    Aspect="Center"
                    IsVisible="{Binding BackgroundImageIsVisible}"
                    Source="{Binding BackgroundImage}" />


                <!--<local:ProGraphicsView
                x:Name="canvas"
                IsLockCheckPoint="{Binding IsLockCheckPoint}"
                IsLockKoKu="{Binding IsLockKoKu}"
                KokuImgTextIsVisible="{Binding KokuImgTextIsVisible}"
                ShapeType="{Binding ShapeType}" />-->
            </Grid>
        </local:ZoomPanContainer>
    </ScrollView>

</ContentView>

