<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Aiko.UI.SystemOptionServerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:Aiko.UI.Behaviors"
    xmlns:local="clr-namespace:Aiko.Common.Converters;assembly=Aiko.Common"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Aiko.UI.ViewModels.PageVMs"
    x:Name="view_SystemOptionServer"
    x:DataType="vm:SystemOptionServerPageVM">
    <ContentView.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding Path=BindingContext, Source={x:Reference view_SystemOptionServer}}"
            Command="{Binding PageLoadCommand}"
            EventName="Loaded" />
    </ContentView.Behaviors>

    <ContentView.Resources>
        <ControlTemplate x:Key="RadioButtonTemplate">
            <Grid
                HorizontalOptions="Start"
                InputTransparent="False"
                VerticalOptions="Center">
                <Grid ColumnDefinitions="auto, *">
                    <Grid HorizontalOptions="End" VerticalOptions="Center">
                        <Ellipse
                            HeightRequest="18"
                            HorizontalOptions="Center"
                            Stroke="{DynamicResource RadioButtonTextColor}"
                            StrokeThickness="2"
                            VerticalOptions="Center"
                            WidthRequest="18" />
                        <Ellipse
                            x:Name="check"
                            Fill="{DynamicResource RadioButtonTextColor}"
                            HeightRequest="10"
                            HorizontalOptions="Center"
                            Opacity="0"
                            VerticalOptions="Center"
                            WidthRequest="10">
                            <Ellipse.Triggers>
                                <DataTrigger
                                    Binding="{Binding IsChecked, Source={RelativeSource TemplatedParent}}"
                                    TargetType="Ellipse"
                                    Value="True">
                                    <Setter Property="Opacity" Value="1" />
                                </DataTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    <Label
                        Grid.Column="1"
                        Margin="5,0,0,0"
                        FontAttributes="{TemplateBinding FontAttributes}"
                        FontFamily="{TemplateBinding FontFamily}"
                        FontSize="{TemplateBinding FontSize}"
                        HorizontalOptions="Start"
                        Text="{TemplateBinding Content}"
                        TextColor="{TemplateBinding TextColor}"
                        VerticalOptions="Center" />
                </Grid>
            </Grid>
        </ControlTemplate>
        <Style x:Key="IpadOptimizedRadio" TargetType="RadioButton">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="OpenSansRegular" />
            <Setter Property="TextColor" Value="{DynamicResource RadioButtonTextColor}" />
            <Setter Property="ControlTemplate" Value="{StaticResource RadioButtonTemplate}" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="MinimumHeightRequest" Value="44" />
            <Setter Property="MinimumWidthRequest" Value="44" />
        </Style>
    </ContentView.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">
            <Grid>
                <Border
                    Padding="20,25,20,15"
                    Stroke="#FF8B8B8B"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1">
                    <HorizontalStackLayout HorizontalOptions="Start" Spacing="40">
                        <RadioButton
                            x:Name="rdbtn_jpeg"
                            Content="JPEG"
                            GroupName="imgType"
                            IsChecked="{Binding IsJepg}"
                            Style="{StaticResource IpadOptimizedRadio}" />

                        <!--  SVG 按钮  -->
                        <RadioButton
                            x:Name="rdbtn_svg"
                            Content="SVG"
                            GroupName="imgType"
                            Style="{StaticResource IpadOptimizedRadio}">
                            <RadioButton.Triggers>
                                <DataTrigger
                                    Binding="{Binding IsJepg}"
                                    TargetType="RadioButton"
                                    Value="False">
                                    <Setter Property="IsChecked" Value="True" />
                                </DataTrigger>
                            </RadioButton.Triggers>
                        </RadioButton>
                    </HorizontalStackLayout>
                </Border>
                <Label
                    Margin="15,-10,0,0"
                    Padding="5,0"
                    BackgroundColor="{DynamicResource PageBackgroundColor}"
                    FontSize="Body"
                    HorizontalOptions="Start"
                    Text="写真ファイル形式"
                    VerticalOptions="Start" />
            </Grid>

            <Grid>
                <Border
                    Padding="20,25,20,20"
                    Stroke="#FF8B8B8B"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="160, *">
                            <Label
                                FontSize="Body"
                                Text="品質"
                                VerticalTextAlignment="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Entry
                                    x:Name="ety_ImageQuality"
                                    HorizontalOptions="Start"
                                    Text="{Binding ImageQuality}"
                                    WidthRequest="150">
                                    <Entry.Behaviors>
                                        <behaviors:NumericOnlyBehavior MaxLength="3" />
                                    </Entry.Behaviors>
                                </Entry>
                                <Label FontSize="Body" Text="10～100の数字を入力してください。" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
                <Label
                    Margin="15,-10,0,0"
                    Padding="5,0"
                    BackgroundColor="{DynamicResource PageBackgroundColor}"
                    FontSize="Body"
                    HorizontalOptions="Start"
                    Text="写真圧縮設定"
                    VerticalOptions="Start" />
            </Grid>

            <Grid>
                <Border
                    Padding="20,25,20,20"
                    Stroke="#FF8B8B8B"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="160, auto,auto,auto">

                            <Label
                                FontSize="Body"
                                Text="メインカメラ解像度"
                                VerticalTextAlignment="Center" />

                            <Picker
                                Grid.Column="1"
                                HorizontalOptions="Start"
                                ItemsSource="{Binding RearResolutions}"
                                SelectedIndex="{Binding SelectedRearResolutionIndex}"
                                WidthRequest="150" />
                            <Label
                                Grid.Column="2"
                                Margin="20,0,0,0"
                                FontSize="Body"
                                Text="フロントカメラ解像度"
                                VerticalTextAlignment="Center" />

                            <Picker
                                Grid.Column="3"
                                Margin="10,0,0,0"
                                HorizontalOptions="Start"
                                ItemsSource="{Binding FrontResolutions}"
                                SelectedIndex="{Binding SelectedFrontResolutionIndex}"
                                WidthRequest="150" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
                <Label
                    Margin="15,-10,0,0"
                    Padding="5,0"
                    BackgroundColor="{DynamicResource PageBackgroundColor}"
                    FontSize="Body"
                    HorizontalOptions="Start"
                    Text="カメラ解像度設定"
                    VerticalOptions="Start" />
            </Grid>

            <Grid>
                <Border
                    Padding="20,25,20,20"
                    Stroke="#FF8B8B8B"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1">
                    <Grid ColumnDefinitions="160, *">
                        <Label
                            FontSize="Body"
                            Text="フォントサイズ"
                            VerticalTextAlignment="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Entry
                                x:Name="ety_BlackFontSize"
                                HorizontalOptions="Start"
                                Text="{Binding BlackFontSize}"
                                WidthRequest="150">
                                <Entry.Behaviors>
                                    <behaviors:NumericOnlyBehavior MaxLength="2" />
                                </Entry.Behaviors>
                            </Entry>
                            <Label FontSize="Body" Text="10～16の数字を入力してください。" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
                <Label
                    Margin="15,-10,0,0"
                    Padding="5,0"
                    BackgroundColor="{DynamicResource PageBackgroundColor}"
                    FontSize="Body"
                    HorizontalOptions="Start"
                    Text="黒板設定"
                    VerticalOptions="Start" />
            </Grid>

            <Grid>
                <Border
                    Padding="20,25,20,20"
                    Stroke="#FF8B8B8B"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1">
                    <Grid ColumnDefinitions="160, *">
                        <Label
                            FontSize="Body"
                            Text="保存日数"
                            VerticalTextAlignment="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Entry
                                x:Name="ety_Savedays"
                                HorizontalOptions="Start"
                                Text="{Binding SaveDays}"
                                WidthRequest="150">
                                <Entry.Behaviors>
                                    <behaviors:NumericOnlyBehavior MaxLength="3" />
                                </Entry.Behaviors>
                            </Entry>
                            <Label FontSize="Body" Text="1～180の数字を入力してください。" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
                <Label
                    Margin="15,-10,0,0"
                    Padding="5,0"
                    BackgroundColor="{DynamicResource PageBackgroundColor}"
                    FontSize="Body"
                    HorizontalOptions="Start"
                    Text="写真データの保存期間"
                    VerticalOptions="Start" />
            </Grid>

            <Button
                x:Name="btn_Save"
                Margin="0,10,0,20"
                Command="{Binding SaveCommand}"
                FontAttributes="Bold"
                HeightRequest="45"
                HorizontalOptions="End"
                Text="保存"
                WidthRequest="120" />
        </VerticalStackLayout>
    </ScrollView>
</ContentView>
