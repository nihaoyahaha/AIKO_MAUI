<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Aiko.UI.MapListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Aiko.UI.ViewModels.PageVMs"
    x:DataType="vm:MapListPageVM"
    xmlns:local="clr-namespace:Aiko.UI"
    Shell.NavBarIsVisible="False">

    <Grid BackgroundColor="White">

        <!-- 当前图片 -->
        <Grid x:Name="MainGridView" BackgroundColor="White" IsClippedToBounds="True">
            <Grid.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Left"
                            Swiped="OnSwipeLeft" />
                <SwipeGestureRecognizer Direction="Right"
                            Swiped="OnSwipeRight" />
            </Grid.GestureRecognizers>
            <local:PinchToZoomContainer x:Name="pinchToZoom">
                <AbsoluteLayout x:Name="ZoomLayer">
                    <Image x:Name="ContainerImg" 
                           Source="{Binding CurrentImage}"
                           Aspect="AspectFit"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill" 
                           Loaded="OnContainerImgLoaded"/>
                </AbsoluteLayout>
            </local:PinchToZoomContainer>
        </Grid>

        <!-- 左右箭头 -->
        <Grid ColumnDefinitions="Auto,*,Auto"
              Margin="10,0"
              VerticalOptions="Center"
              HorizontalOptions="Fill"
              InputTransparent="True"
              CascadeInputTransparent="False"
              ZIndex="10">

            <ImageButton Grid.Column="0"
                         InputTransparent="False"
                         Source="arrowleft.png"
                         Command="{Binding PreviousImageCommand}"
                         IsEnabled="{Binding CanGoPrevious}"
                         BackgroundColor="#66000000"
                         CornerRadius="24"
                         WidthRequest="48"
                         HeightRequest="48"
                         Padding="10" />

            <ImageButton Grid.Column="2"
                         InputTransparent="False"
                         Source="arrowleft.png"
                         Rotation="180"
                         Command="{Binding NextImageCommand}"
                         IsEnabled="{Binding CanGoNext}"
                         BackgroundColor="#66000000"
                         CornerRadius="24"
                         WidthRequest="48"
                         HeightRequest="48"
                         Padding="10" />
        </Grid>

        <!-- 页码 -->
        <Label Text="{Binding PageInfo}"
               HorizontalOptions="Center"
               VerticalOptions="End"
               Margin="0,0,0,20"
               Padding="10,4"
               TextColor="White"
               BackgroundColor="#66000000"
               InputTransparent="True"
               ZIndex="10" />

        <!-- 返回按钮 -->
        <ImageButton Source="arrowleft.png"
                     Command="{Binding GoBackCommand}"
                     BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                     CornerRadius="5"
                     WidthRequest="48"
                     HeightRequest="48"
                     Padding="10"
                     HorizontalOptions="End"
                     VerticalOptions="Start"
                     Margin="0,5,5,0"
                     ZIndex="10">
            <ImageButton.Shadow>
                <Shadow Brush="Black"
                        Offset="2,2"
                        Radius="5"
                        Opacity="0.3" />
            </ImageButton.Shadow>
        </ImageButton>
    </Grid>
</ContentPage>