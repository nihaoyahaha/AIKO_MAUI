                            <BoxView x:Name="InkToolButton_Empty" Style="{StaticResource InkToolButtonStyle}">
                                <BoxView.IsVisible>
                                    <MultiBinding Converter="{StaticResource AndConverter}">
                                        <Binding Path="IsSvg" />
                                        <Binding Path="IsStrokesVisible" />
                                        <Binding Path="EmptySelected" />
                                    </MultiBinding>
                                </BoxView.IsVisible>
                            </BoxView>
                        </Grid>

                        <Grid x:Name="InkControl" Grid.Column="14" ColumnDefinitions="*,*,*,*">

                            <Border x:Name="bord_photo"
                                    Grid.Column="0"
                                    WidthRequest="60"
                                    HeightRequest="30"
                                    Margin="2"
                                    HorizontalOptions="Center"
                                    Background="Pink"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:CheckPointDetailPageVM}}, Path=IsSvg}">
                                <Label VerticalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" Text="写真" TextColor="Black" />
                            </Border>

                            <Border x:Name="bord_greenbk"
                                    Grid.Column="1"
                                    WidthRequest="60"
                                    HeightRequest="30"
                                    Margin="2"
                                    HorizontalOptions="Center"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:CheckPointDetailPageVM}}, Path=IsSvg}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FFCCCCCC" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding Source={RelativeSource AncestorType={x:Type vm:CheckPointDetailPageVM}}, Path=IsBlackboardVisible}" Value="True">
                                                <Setter Property="Background" Value="Pink" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnBtnBlackboardClicked" />
                                </Border.GestureRecognizers>
                                <Label VerticalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" Text="黒板" TextColor="Black" />
                            </Border>

                            <Border x:Name="bord_ink"
                                    Grid.Column="2"
                                    WidthRequest="60"
                                    HeightRequest="30"
                                    Margin="2"
                                    HorizontalOptions="Center"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:CheckPointDetailPageVM}}, Path=IsSvg}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FFCCCCCC" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding Source={RelativeSource AncestorType={x:Type vm:CheckPointDetailPageVM}}, Path=IsStrokesVisible}" Value="True">
                                                <Setter Property="Background" Value="Pink" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnBtnInkClicked" />
                                </Border.GestureRecognizers>
                                <Label VerticalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" Text="注釈" TextColor="Black" />
                            </Border>

                            <Border x:Name="btnSaveSyg"
                                    Grid.Column="3"
                                    WidthRequest="60"
                                    HeightRequest="30"
                                    Margin="2"
                                    HorizontalOptions="Center"
                                    Background="#FFCCCCCC"
                                    IsVisible="True">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnBtnSaveClicked" />
                                </Border.GestureRecognizers>
                                <Label VerticalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" Text="保存" TextColor="Black" />
                            </Border>

                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="20" Padding="5">

                        <Grid Grid.Column="0"
                              RowDefinitions="Auto, Auto" 
                              ColumnDefinitions="Auto, *" 
                              RowSpacing="5" 
                              ColumnSpacing="5">

                            <Label Grid.Row="0" Grid.Column="0" Text="撮影方向" VerticalTextAlignment="Center" VerticalOptions="Center" HorizontalOptions="End" />
                            <Grid Grid.Row="0" Grid.Column="1" VerticalOptions="Center">
                                
                                <Grid HeightRequest="45" VerticalOptions="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="45" />
                                    </Grid.ColumnDefinitions>

                                    <Picker x:Name="HiddenPicker"
                                            Grid.ColumnSpan="2"
                                            ItemsSource="{Binding DirsList}"
                                            SelectedItem="{Binding Dirs}"
                                            ItemDisplayBinding="{Binding DisplyName}"
                                            Opacity="0.01"
                                            VerticalOptions="Fill"
                                            HorizontalOptions="Fill" />

                                    <Entry Grid.Column="0"
                                           Text="{Binding DirsDisplyName}"
                                           VerticalOptions="Center" />

                                    <Grid Grid.Column="1" BackgroundColor="{DynamicResource PickerBackgroundColor}">
                                        <Image Source="arrow.png"
                                               WidthRequest="20"
                                               HeightRequest="20"
                                               VerticalOptions="Center"
                                               HorizontalOptions="Center"
                                               InputTransparent="True" />

                                        <Button BackgroundColor="Transparent"
                                                Clicked="OnArrowClicked"
                                                VerticalOptions="Fill"
                                                HorizontalOptions="Fill" />
                                    </Grid>
                                </Grid>

                            </Grid>

                            <Label Grid.Row="1" Grid.Column="0" Text="備考" VerticalTextAlignment="Center" VerticalOptions="Center" HorizontalOptions="End" />
                            <Entry Grid.Row="1"
                                   Grid.Column="1"
                                   x:Name="txt_Comment"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Center"
                                   MinimumHeightRequest="40"
                                   Text="{Binding Comment}" />
                        </Grid>

                        <Grid Grid.Column="1"
                              RowDefinitions="Auto, Auto" 
                              ColumnDefinitions="Auto, *" 
                              RowSpacing="5" 
                              ColumnSpacing="5">

                            <Label Grid.Row="0" Grid.Column="0" Text="撮影日時" VerticalTextAlignment="Center" VerticalOptions="Center" />
                            <Entry Grid.Row="0"
                                   Grid.Column="1"
                                   x:Name="txt_Date"
                                   IsReadOnly="True"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Center"
                                   MinimumHeightRequest="40"
                                   Text="{Binding Date}"
                                   BackgroundColor="{DynamicResource EntryReadOnlyBackgroundColor}" />

                            <Label Grid.Row="1" Grid.Column="0" Text="撮影者" VerticalTextAlignment="Center" VerticalOptions="Center" />
                            <Entry Grid.Row="1"
                                   Grid.Column="1"
                                   x:Name="txt_Author"
                                   IsReadOnly="True"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Center"
                                   MinimumHeightRequest="40"
                                   Text="{Binding Author}"
                                   BackgroundColor="{DynamicResource EntryReadOnlyBackgroundColor}" />
                        </Grid>

                    </Grid>
                </Grid>

                <Grid Grid.Column="1" RowDefinitions="40, *">

                    <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, *, Auto" Padding="5,0">

                        <Grid x:Name="CheckOptions"
                              Margin="0,0,10,0"
                              BackgroundColor="#FFCCCCCC"
                              ColumnSpacing="10"
                              HeightRequest="33"
                              HorizontalOptions="Start"
                              VerticalOptions="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Margin="3,0,0,0"
                                    HeightRequest="26"
                                    Stroke="Blue"
                                    StrokeThickness="{Binding Checkrsl1StrokeThickness}"
                                    WidthRequest="26">
                                <Image x:Name="imgBtn_rsl1"
                                       Aspect="Fill"
                                       HeightRequest="16"
                                       HorizontalOptions="Center"
                                       Source="checkrsl1.png"
                                       ToolTipProperties.Text="未確認"
                                       VerticalOptions="Center"
                                       WidthRequest="16">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignOptionTapped" CommandParameter="0" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Border>
                            <Border Grid.Column="1"
                                    Margin="3,0,0,0"
                                    HeightRequest="26"
                                    Stroke="Blue"
                                    StrokeThickness="{Binding Checkrsl2StrokeThickness}"
                                    WidthRequest="26">
                                <Image x:Name="imgBtn_rsl2"
                                       Aspect="Fill"
                                       HeightRequest="16"
                                       HorizontalOptions="Center"
                                       Source="checkrsl2.png"
                                       ToolTipProperties.Text="不合格"
                                       VerticalOptions="Center"
                                       WidthRequest="16">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignOptionTapped" CommandParameter="1" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Border>
                            <Border Grid.Column="2"
                                    Margin="3,0,0,0"
                                    HeightRequest="26"
                                    Stroke="Blue"
                                    StrokeThickness="{Binding Checkrsl4StrokeThickness}"
                                    WidthRequest="26">
                                <Image x:Name="imgBtn_rsl4"
                                       Aspect="Fill"
                                       HeightRequest="16"
                                       HorizontalOptions="Center"
                                       Source="checkrsl4.png"
                                       ToolTipProperties.Text="合格"
                                       VerticalOptions="Center"
                                       WidthRequest="16">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignOptionTapped" CommandParameter="2" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Border>
                            <Border Grid.Column="3"
                                    Margin="3,0,3,0"
                                    HeightRequest="26"
                                    Stroke="Blue"
                                    StrokeThickness="{Binding Checkrsl5StrokeThickness}"
                                    WidthRequest="26">
                                <Image x:Name="imgBtn_rsl5"
                                       Aspect="Fill"
                                       HeightRequest="16"
                                       HorizontalOptions="Center"
                                       Source="checkrsl5.png"
                                       ToolTipProperties.Text="是正済"
                                       VerticalOptions="Center"
                                       WidthRequest="16">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignOptionTapped" CommandParameter="3" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Border>

                        </Grid>

                        <StackLayout Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Border WidthRequest="60" HeightRequest="30"
                                    HorizontalOptions="Center" Background="#5B9BD5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleImageGalleryCommand}" />
                                </Border.GestureRecognizers>
                                <Label HorizontalOptions="Center" 
                                       VerticalOptions="Center" 
                                       Text="写真" 
                                       FontSize="14"
                                       TextColor="White"
                                       BackgroundColor="Transparent"
                                       VerticalTextAlignment="Center" />
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsImageGalleryVisible}" Value="True">
                                        <Setter Property="Background" Value="#4472C4" />
                                    </DataTrigger>
                                </Border.Triggers>
                            </Border>
                            <Border WidthRequest="60" HeightRequest="30"
                                    HorizontalOptions="Center" Background="#5B9BD5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleImageGridCommand}" />
                                </Border.GestureRecognizers>
                                <Label HorizontalOptions="Center" 
                                       VerticalOptions="Center" 
                                       Text="断面図" 
                                       FontSize="14"
                                       TextColor="White"
                                       BackgroundColor="Transparent"
                                       VerticalTextAlignment="Center" />
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsImageGridVisible}" Value="True">
                                        <Setter Property="Background" Value="#4472C4" />
                                    </DataTrigger>
                                </Border.Triggers>
                            </Border>
                            <Image Source="clear.png" WidthRequest="30" HeightRequest="30" >
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding DeleteImageCommand}" />
                                </Image.GestureRecognizers>
                            </Image>
                        </StackLayout>

                        <StackLayout Grid.Column="3" Orientation="Horizontal" Spacing="8">
                            <Label VerticalOptions="Center" FontSize="16" Text="{Binding Summary}" VerticalTextAlignment="Center" />
                            <Border WidthRequest="80" HeightRequest="30" Margin="2" 
                                    HorizontalOptions="Center" Background="#CCCCCC">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleSortCommand}" />
                                </Border.GestureRecognizers>
                                <Label HorizontalOptions="Center" 
                                       VerticalOptions="Center" 
                                       Text="{Binding SortText}" 
                                       FontSize="14"
                                       TextColor="#333333"
                                       VerticalTextAlignment="Center" />
                            </Border>
                        </StackLayout>
                    </Grid>

                    <CollectionView x:Name="ImageGallery"
                                    ItemsSource="{Binding ImageList}"
                                    IsVisible="{Binding IsImageGalleryVisible}"
                                    Grid.Row="1"
                                    ItemsUpdatingScrollMode="KeepScrollOffset"
                                    Scrolled="OnCollectionViewScrolled">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="3" VerticalItemSpacing="1" HorizontalItemSpacing="1"/>
                        </CollectionView.ItemsLayout>

                        <CollectionView.Footer>
                            <VerticalStackLayout IsVisible="{Binding IsFooterVisible}" HeightRequest="50" HorizontalOptions="Center">
                                <ActivityIndicator IsRunning="True" WidthRequest="30" HeightRequest="30"/>
                                <Label Text="Loading..." FontSize="12" HorizontalOptions="Center" VerticalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </CollectionView.Footer>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:InkImage">
                                <Border x:Name="ItemBorder" Padding="2">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnGalleryItemTapped" />

                                        <DragGestureRecognizer DragStarting="OnDragStarting" CanDrag="True" />

                                        <DropGestureRecognizer AllowDrop="True" 
                                                               DragOver="OnDragOver" 
                                                               DragLeave="OnDragLeave" 
                                                               Drop="OnDrop" />
                                    </Border.GestureRecognizers>

                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding CacheUpdater}" Value="True">
                                            <Setter TargetName="ImageGalleryItemPlaceholder" Property="VisualElement.IsVisible" Value="False"/>
                                            <Setter TargetName="ImageGalleryItemImage" Property="VisualElement.IsVisible" Value="True"/>
                                        </DataTrigger>

                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SelectedImageColor}" />
                                            <Setter Property="Stroke" Value="#007AFF" />
                                            <Setter Property="StrokeThickness" Value="2" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Grid ColumnDefinitions="4, *, 4">

                                        <BoxView Grid.Column="0" 
                                                 x:Name="LeftDropIndicator" 
                                                 Color="Transparent" 
                                                 VerticalOptions="Fill" 
                                                 HorizontalOptions="Fill" 
                                                 Margin="0,0,2,0"/>

                                        <StackLayout Grid.Column="1">
                                            <Grid ColumnDefinitions="Auto, *, *, *" ColumnSpacing="5" VerticalOptions="Center">
                                                <Image Grid.Column="0"
                                                       x:Name="imgBtn_rsl_display" 
                                                       Margin="4,0,0,0"
                                                       Aspect="Fill"
                                                       HeightRequest="16"
                                                       WidthRequest="16"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       BackgroundColor="#CCCCCC">
                                                    <Image.Source>
                                                        <Binding Path="Sign">
                                                            <Binding.FallbackValue>checkrsl1.png</Binding.FallbackValue>
                                                            <Binding.TargetNullValue>checkrsl1.png</Binding.TargetNullValue>
                                                        </Binding>
                                                    </Image.Source>

                                                    <Image.Triggers>
                                                        <DataTrigger TargetType="Image" Binding="{Binding Sign}" Value="0">
                                                            <Setter Property="Source" Value="checkrsl1.png" />
                                                        </DataTrigger>

                                                        <DataTrigger TargetType="Image" Binding="{Binding Sign}" Value="1">
                                                            <Setter Property="Source" Value="checkrsl2.png" />
                                                        </DataTrigger>

                                                        <DataTrigger TargetType="Image" Binding="{Binding Sign}" Value="2">
                                                            <Setter Property="Source" Value="checkrsl4.png" />
                                                        </DataTrigger>

                                                        <DataTrigger TargetType="Image" Binding="{Binding Sign}" Value="3">
                                                            <Setter Property="Source" Value="checkrsl5.png" />
                                                        </DataTrigger>
                                                    </Image.Triggers>
                                                </Image>

                                                <Border x:Name="brd_photo" Grid.Column="1" HorizontalOptions="Fill" Background="Pink">
                                                    <Label Text="写真" HorizontalOptions="Center" VerticalOptions="Center" FontSize="Caption" TextColor="Black" VerticalTextAlignment="Center" />
                                                </Border>

                                                <Border x:Name="brd_greenbk" Grid.Column="2" HorizontalOptions="Fill" IsVisible="{Binding IsSvg}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FFCCCCCC" />
                                                            <Style.Triggers>
                                                                <DataTrigger TargetType="Border" Binding="{Binding IsBlackboardVisible}" Value="True">
                                                                    <Setter Property="Background" Value="Pink" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Label Text="黒板" HorizontalOptions="Center" VerticalOptions="Center" FontSize="Caption" TextColor="Black" VerticalTextAlignment="Center" />
                                                </Border>

                                                <Border x:Name="brd_inkCanvas" Grid.Column="3" HorizontalOptions="Fill" IsVisible="{Binding IsSvg}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FFCCCCCC" />
                                                            <Style.Triggers>
                                                                <DataTrigger TargetType="Border" Binding="{Binding IsStrokesVisible}" Value="True">
                                                                    <Setter Property="Background" Value="Pink" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Label Text="注釈" HorizontalOptions="Center" VerticalOptions="Center" FontSize="Caption" TextColor="Black" VerticalTextAlignment="Center" />
                                                </Border>
                                            </Grid>

                                            <Grid HeightRequest="102" BackgroundColor="White" Margin="1">
                                                <Label x:Name="ImageGalleryItemPlaceholder" 
                                                       Text="Loading..." 
                                                       TextColor="#AAAAAA" 
                                                       HorizontalOptions="Center" 
                                                       VerticalOptions="Center" 
                                                       FontSize="10"
                                                       VerticalTextAlignment="Center"/>
                                                <ff:CachedImage x:Name="ImageGalleryItemImage"
                                                                Source="{Binding InkImageSource}"
                                                                Aspect="AspectFit"
                                                                IsVisible="False"
                                                                DownsampleToViewSize="True"
                                                                CacheType="None"
                                                                LoadingDelay="0"
                                                                Success="OnImageVisualized">
                                                    
                                                    <ff:CachedImage.Triggers>
                                                        <DataTrigger TargetType="ff:CachedImage" Binding="{Binding CacheUpdater}" Value="True">
                                                            <Setter Property="IsVisible" Value="True"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="ff:CachedImage" Binding="{Binding CacheUpdater}" Value="False">
                                                            <Setter Property="IsVisible" Value="False"/>
                                                        </DataTrigger>
                                                    </ff:CachedImage.Triggers>
                                                </ff:CachedImage>
                                            </Grid>

                                            <StackLayout Padding="4,0,4,4" Spacing="0">
                                                <Label Text="{Binding Date}" FontSize="14" VerticalTextAlignment="Center" LineBreakMode="NoWrap"/>
                                                <Label Text="{Binding DirsDisplyName}" FontSize="14" VerticalTextAlignment="Center" LineBreakMode="NoWrap"/>
                                                <Label Text="{Binding Comment}" FontSize="14" VerticalTextAlignment="Center" LineBreakMode="NoWrap"/>
                                            </StackLayout>
                                        </StackLayout>

                                        <BoxView Grid.Column="2" 
                                                 x:Name="RightDropIndicator" 
                                                 Color="Transparent" 
                                                 VerticalOptions="Fill" 
                                                 HorizontalOptions="Fill" 
                                                 Margin="0,0,2,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid x:Name="ImageGrid"
                          IsVisible="{Binding IsImageGridVisible}"
                          Grid.Row="1"
                          Background="#e8e8e8"
                          IsClippedToBounds="True">
                        <local:PinchToZoomContainer x:Name="DanmImagePinchToZoom">
                            <AbsoluteLayout x:Name="DanmImageZoomLayer"
                                            HorizontalOptions="Start"
                                            VerticalOptions="Start">
                                <Image x:Name="DanmImage"
                                       AbsoluteLayout.LayoutBounds="0,0,1,1"
                                       AbsoluteLayout.LayoutFlags="All"
                                       Aspect="Fill"
                                       Source="{Binding DanmImageSource}" />
                            </AbsoluteLayout>
                        </local:PinchToZoomContainer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="SettingsOverlay" IsVisible="False" ZIndex="99">
            <BoxView Color="Transparent" BackgroundColor="#01000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOverlayTapped"/>
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border x:Name="SettingsPanel"
                    BackgroundColor="#F2F2F2"
                    Stroke="#E0E0E0"
                    StrokeThickness="1"
                    WidthRequest="336"
                    HorizontalOptions="Start"
                    VerticalOptions="End"
                    Margin="20,0,0,90" 
                    Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Opacity="0.2" Radius="10"/>
                </Border.Shadow>

                <StackLayout Spacing="15">
                    <!-- 颜色选择区域 -->
                    <StackLayout x:Name="ColorSection" Spacing="5">
                        <Label Text="色" FontSize="12" Margin="0,0,0,5" VerticalTextAlignment="Center"/>

                        <FlexLayout x:Name="ColorFlexLayout"
                                    BindableLayout.ItemsSource="{Binding ColorPalette}"
                                    Wrap="Wrap"
                                    Direction="Row"
                                    JustifyContent="Start"
                                    AlignContent="Start"
                                    AlignItems="Start">

                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="m:Color">
                                    <Border StrokeThickness="2"
                                            StrokeShape="RoundRectangle 18"
                                            HeightRequest="36"
                                            WidthRequest="36"
                                            Margin="4"
                                            BackgroundColor="{Binding .}"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center">

                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup Name="SelectionStates">
                                                <VisualState Name="Selected">
                                                    <VisualState.Setters>
                                                        <Setter Property="Stroke" Value="#0078D7" />
                                                        <Setter Property="Scale" Value="1.1" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                                <VisualState Name="Normal">
                                                    <VisualState.Setters>
                                                        <Setter Property="Stroke" Value="Transparent" />
                                                        <Setter Property="Scale" Value="1.0" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnColorTapped" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </StackLayout>

                    <!-- 笔画预览和大小设置区域 -->
                    <StackLayout x:Name="StrokePreviewSection" Spacing="10">
                        <Label Text="サイズ" FontSize="12" VerticalTextAlignment="Center"/>

                        <Grid x:Name="StrokePreviewGrid" HeightRequest="80" BackgroundColor="Transparent" Margin="0,5">
                            <skia:SKCanvasView x:Name="StrokePreview"
                                               VerticalOptions="Fill"
                                               HorizontalOptions="Fill"
                                               PaintSurface="OnStrokePreviewPaintSurface"
                                               Margin="15,0,15,0"/>
                        </Grid>

                        <StackLayout x:Name="SizeSliderSection" IsVisible="False" Spacing="15">
                            <Grid ColumnDefinitions="70,*,40" Margin="5,0,5,0">
                                <Label Text="円形-半径" 
                                       Grid.Column="0"
                                       VerticalOptions="Center" 
                                       FontSize="14" 
                                       WidthRequest="70"
                                       VerticalTextAlignment="Center"/>
                                <Slider x:Name="SizeSlider" 
                                        Grid.Column="1"
                                        Minimum="1" 
                                        Maximum="24" 
                                        VerticalOptions="Center"
                                        ValueChanged="OnSizeChanged"
                                        MinimumTrackColor="#0078D4"
                                        MaximumTrackColor="#A1A1A1"/>
                                <Label Grid.Column="2"
                                       Text="{Binding Source={x:Reference SizeSlider}, Path=Value, StringFormat='{0:F0}'}"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </StackLayout>

                        <!-- 矩形大小设置区域 -->
                        <StackLayout x:Name="FixedRectSettingsSection" IsVisible="False" Spacing="15">
                            <StackLayout Spacing="10">
                                <Grid ColumnDefinitions="70,*,40" Margin="5,0,5,0">
                                    <Label Text="四角形-幅" 
                                           Grid.Column="0"
                                           VerticalOptions="Center" 
                                           FontSize="14" 
                                           WidthRequest="70"
                                           VerticalTextAlignment="Center"/>
                                    <Slider x:Name="FixedRectWidthSlider" 
                                            Grid.Column="1"
                                            Minimum="5" 
                                            Maximum="200" 
                                            Value="20"
                                            VerticalOptions="Center"
                                            ValueChanged="OnFixedRectDimensionChanged"
                                            MinimumTrackColor="#0078D4"
                                            MaximumTrackColor="#A1A1A1"/>
                                    <Label Grid.Column="2"
                                           Text="{Binding Source={x:Reference FixedRectWidthSlider}, Path=Value, StringFormat='{0:F0}'}"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           VerticalTextAlignment="Center"/>
                                </Grid>
                            </StackLayout>

                            <StackLayout Spacing="10">
                                <Grid ColumnDefinitions="70,*,40" Margin="5,0,5,0">
                                    <Label Text="四角形-長" 
                                           Grid.Column="0"
                                           VerticalOptions="Center" 
                                           FontSize="14" 
                                           WidthRequest="70"
                                           VerticalTextAlignment="Center"/>
                                    <Slider x:Name="FixedRectHeightSlider" 
                                            Grid.Column="1"
                                            Minimum="5" 
                                            Maximum="200" 
                                            Value="10"
                                            VerticalOptions="Center"
                                            ValueChanged="OnFixedRectDimensionChanged"
                                            MinimumTrackColor="#0078D4"
                                            MaximumTrackColor="#A1A1A1"/>
                                    <Label Grid.Column="2"
                                           Text="{Binding Source={x:Reference FixedRectHeightSlider}, Path=Value, StringFormat='{0:F0}'}"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           VerticalTextAlignment="Center"/>
                                </Grid>
                            </StackLayout>
                        </StackLayout>
                    </StackLayout>

                    <!-- 字体预览和设置区域 -->
                    <StackLayout x:Name="FontPreviewSection" IsVisible="False" Spacing="15">
                        <StackLayout Spacing="5">
                            <Label Text="サイズ" FontSize="12" VerticalTextAlignment="Center"/>
                            <Grid HeightRequest="60" BackgroundColor="Transparent">
                                <skia:SKCanvasView x:Name="FontPreview"
                                                   HeightRequest="60"
                                                   HorizontalOptions="Fill"
                                                   PaintSurface="OnFontPreviewPaintSurface"/>
                            </Grid>
                        </StackLayout>

                        <Grid ColumnDefinitions="Auto, *" Margin="0,10,0,0">
                            <Label Text="フォント" 
                                   Grid.Column="0"
                                   VerticalOptions="Center" 
                                   FontSize="14" 
                                   WidthRequest="75"
                                   VerticalTextAlignment="Center"/>
                            <Border Grid.Column="1" 
                                    Stroke="#D0D0D0" 
                                    StrokeThickness="1" 
                                    Padding="5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="4"/>
                                </Border.StrokeShape>
                                <Picker x:Name="FontPicker" 
                                        SelectedIndexChanged="OnFontChanged"
                                        TextColor="Black"
                                        BackgroundColor="Transparent">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>ヒラギノ丸ゴ ProN</x:String>
                                            <x:String>ヒラギノ明朝 ProN</x:String>
                                            <x:String>ヒラギノ角ゴシック</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="Auto, *" Margin="0,10,0,0">
                            <Label Text="フォントサイズ" 
                                   Grid.Column="0"
                                   VerticalOptions="Center" 
                                   FontSize="10" 
                                   WidthRequest="75"
                                   VerticalTextAlignment="Center"/>
                            <Border Grid.Column="1" 
                                    Stroke="#D0D0D0" 
                                    StrokeThickness="1" 
                                    Padding="5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="4"/>
                                </Border.StrokeShape>
                                <Picker x:Name="FontSizePicker" 
                                        SelectedIndexChanged="OnFontSizeChanged"
                                        TextColor="Black"
                                        BackgroundColor="Transparent">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:Double}">
                                            <x:Double>12</x:Double>
                                            <x:Double>14</x:Double>
                                            <x:Double>16</x:Double>
                                            <x:Double>18</x:Double>
                                            <x:Double>24</x:Double>
                                            <x:Double>36</x:Double>
                                            <x:Double>48</x:Double>
                                            <x:Double>72</x:Double>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </Border>
                        </Grid>
                    </StackLayout>

                    <!-- 橡皮擦清除按钮 -->
                    <StackLayout x:Name="EraserSection" IsVisible="False" HorizontalOptions="Center">
                        <ImageButton Source="clear.png"
                                     WidthRequest="50"
                                     HeightRequest="50"
                                     Padding="10"
                                     BackgroundColor="#FFF0F0"
                                     CornerRadius="25"
                                     Clicked="OnClearClicked">
                            <ImageButton.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Opacity="0.1" Radius="5"/>
                            </ImageButton.Shadow>
                        </ImageButton>
                    </StackLayout>
                </StackLayout>
            </Border>
        </Grid>

        <Border IsVisible="{Binding Toast.IsVisible}"
                Opacity="{Binding Toast.Opacity}"
                BackgroundColor="#AA000000"
                StrokeShape="Rectangle"
                HorizontalOptions="Center"
                VerticalOptions="Center" 
                Padding="20,10"
                Margin="0,0,0,100"
                InputTransparent="True"
                ZIndex="99">
            <Label Text="{Binding Toast.Message}" 
                   TextColor="White"  
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />
        </Border>
    </Grid>

</ContentPage>