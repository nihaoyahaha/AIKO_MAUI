<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Aiko.UI.UploadPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Aiko.UI.ViewModels.PageVMs"
    x:Name="page_upload"
    Title="データ同期"
    x:DataType="vm:UploadPageVM">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding Path=BindingContext, Source={x:Reference page_upload}}"
            Command="{Binding PageLoadedCommand}"
            EventName="Loaded" />
    </ContentPage.Behaviors>
    <ScrollView Orientation="Both">
        <Grid
            Padding="15"
            MinimumHeightRequest="600"
            MinimumWidthRequest="600">

            <VerticalStackLayout Spacing="20">
                <Border
                    Padding="15"
                    Stroke="#FF8B8B8B"
                    StrokeShape="RoundRectangle 8">
                    <Grid HeightRequest="150" RowDefinitions="*, Auto">
                        <Label VerticalOptions="Start">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="&#10;　　検査結果、確認履歴を同期する。&#10;" />
                                    <Span Text="　　※サーバー・端末は互いの新しいデータを更新します。" TextColor="Red" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <Button
                            x:Name="btnUpload"
                            Grid.Row="1"
                            Command="{Binding DataSynchronizationCommand}"
                            HorizontalOptions="End"
                            Text="同　期"
                            VerticalOptions="End"
                            WidthRequest="100" />
                    </Grid>
                </Border>

                <Border
                    Padding="15"
                    Stroke="#FF8B8B8B"
                    StrokeShape="RoundRectangle 8">
                    <Grid HeightRequest="220" RowDefinitions="*, Auto, Auto">
                        <Label>
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="&#10;　　写真データを同期する。&#10;" />
                                    <Span Text="　　※サーバー・端末は互いの新しいデータを更新します。&#10;" TextColor="Red" />
                                    <Span Text="{Binding SaveDaysMessageInfo}" TextColor="Red" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <HorizontalStackLayout
                            Grid.Row="1"
                            Margin="30,10,0,0"
                            VerticalOptions="Center">
                            <CheckBox x:Name="chkDrawing" IsChecked="{Binding IsCheckDrawing}" />
                            <Label Text="図面ファイルを含む" VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Button
                            x:Name="btnPUpload"
                            Grid.Row="2"
                            Command="{Binding FileSynchronizationCommand}"
                            HorizontalOptions="End"
                            Text="同　期"
                            VerticalOptions="End"
                            WidthRequest="100" />
                    </Grid>
                </Border>

            </VerticalStackLayout>

            <!--  进度条遮罩层  -->
            <Grid
                x:Name="gridProgress"
                BackgroundColor="#B0D3D3D3"
                IsVisible="{Binding IsShowProgressGridFlag}"
                ZIndex="999">
                <VerticalStackLayout
                    Padding="30"
                    BackgroundColor="White"
                    HorizontalOptions="Center"
                    Spacing="15"
                    VerticalOptions="Center">
                    <!--  进度说明  -->
                    <Label
                        x:Name="txtBarName"
                        FontSize="16"
                        HorizontalTextAlignment="Center"
                        Text="{Binding ProgressMessage}"
                        WidthRequest="400" />
                    <!--  ★ 关键：绑定 Progress 属性 ★  -->
                    <ProgressBar
                        x:Name="pBar"
                        HeightRequest="20"
                        Progress="{Binding Progress}"
                        ProgressColor="#512BD4"
                        WidthRequest="400" />
                    <!--  百分比  -->
                    <Label
                        x:Name="percent"
                        FontAttributes="Bold"
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        Text="{Binding PercentText}" />
                    <!--  加载动画  -->
                    <ActivityIndicator
                        HeightRequest="40"
                        IsRunning="{Binding IsShowProgressGridFlag}"
                        WidthRequest="40"
                        Color="#512BD4" />
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>
